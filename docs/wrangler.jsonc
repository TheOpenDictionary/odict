{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-06-21",
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
  "name": "odict-docs",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}
